U <- matrixNormal::I(n)

X <- matrixNormal::rmatnorm(s = 1, M, U, Sigma)
Y <- matrixNormal::rmatnorm(s = 1, M, U, Sigma)

# Hierarchical clustering with average linkage and known Sigma
test.hc <- test.clusters.hc(
  X = X, U = U, Sigma = Sigma,
  NC = 3, clusters = sample(1:3, 2),
  linkage = "average"
